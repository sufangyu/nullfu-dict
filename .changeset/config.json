{
  "$schema": "https://unpkg.com/@changesets/config@3.1.3/schema.json",
  "changelog": [
    "@changesets/cli/changelog",
    {
      "repo": "username/repo",
      "changelogFile": "CHANGELOG.md",
      "unified": true
    }
  ],
  "commit": false,
  "fixed": [],
  "linked": [],
  "access": "public",
  "baseBranch": "main",
  "updateInternalDependencies": "patch",
  "ignore": ["@nullfux/dict-docs"]
}
